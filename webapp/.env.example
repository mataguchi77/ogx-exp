# Required
BEDROCK_AGENT_CORE_GATEWAY_URL=https://your-gateway-id.gateway.bedrock-agentcore.your-region.amazonaws.com/mcp
COGNITO_TOKEN_URL=https://your-domain.auth.your-region.amazoncognito.com/oauth2/token
COGNITO_CLIENT_ID=your_cognito_client_id
COGNITO_CLIENT_SECRET=your_cognito_client_secret

# Optional (defaults shown)
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=ollama/llama3.2
OGX_BASE_URL=http://localhost:8321
PORT=5000

# RAG source — switch between "aws" and "ollama" (default: aws)
#   aws    = uses AWS Knowledge Base via the agent gateway (no local setup needed)
#   ollama = uses local Ollama embeddings + OGX vector store (requires OGX running)
RAG_SOURCE=aws

# Ollama RAG settings (used when RAG_SOURCE=ollama)
EMBEDDING_MODEL=mxbai-embed-large
EMBEDDING_DIMENSION=1024
